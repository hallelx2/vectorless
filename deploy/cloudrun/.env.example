# Copy to deploy/cloudrun/.env and fill in. Never commit .env.

# ── GCP ─────────────────────────────────────────────────────────────
PROJECT_ID=vectorless-prod
REGION=us-central1

# ── LLM provider (Anthropic by default — see server config for others)
ANTHROPIC_API_KEY=sk-ant-...

# ── Neon Postgres (two databases in one project)
# Get from https://console.neon.tech → your project → Connection Details
NEON_SERVER_URL=postgres://user:password@ep-xxxx.us-east-1.aws.neon.tech/server?sslmode=require
NEON_CP_URL=postgres://user:password@ep-xxxx.us-east-1.aws.neon.tech/control_plane?sslmode=require

# ── Cloudflare R2 (S3-compatible object storage)
# Get from https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
R2_BUCKET=vectorless-docs
R2_ACCESS_KEY=...
R2_SECRET_KEY=...

# ── Domain (already managed elsewhere — Cloudflare DNS recommended)
DOMAIN=vectorless.store
API_HOSTNAME=api.vectorless.store

# ── Optional: pre-generated shared secrets. Leave blank to auto-generate.
#    If you set them here, the deploy scripts will reuse them; otherwise
#    they get generated and saved into this .env on first run.
UPSTREAM_AUTH_TOKEN=
OAUTH_JWT_SECRET=
DASHBOARD_SERVICE_TOKEN=
