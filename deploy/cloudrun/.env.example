# Copy to deploy/cloudrun/.env and fill in. Never commit .env.

# ── GCP ─────────────────────────────────────────────────────────────
PROJECT_ID=vectorless-prod
REGION=us-central1

# ── LLM provider (Gemini by default — see server config for others)
GEMINI_API_KEY=AIza...

# ── Neon Postgres (two databases in one project)
# Get from https://console.neon.tech → your project → Connection Details
NEON_SERVER_URL=postgres://user:password@ep-xxxx.us-east-1.aws.neon.tech/vectorless_server?sslmode=require
NEON_CP_URL=postgres://user:password@ep-xxxx.us-east-1.aws.neon.tech/vectorless_control?sslmode=require

# ── Object storage (S3-compatible — Backblaze B2, Cloudflare R2, AWS S3)
# B2:  endpoint shown when you create the bucket; region in the URL
# R2:  https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com, region "auto"
# S3:  https://s3.us-east-1.amazonaws.com, region "us-east-1"
STORAGE_ENDPOINT=https://s3.us-west-002.backblazeb2.com
STORAGE_REGION=us-west-002
STORAGE_BUCKET=vectorless-docs
STORAGE_ACCESS_KEY=...
STORAGE_SECRET_KEY=...

# ── Domain (already managed elsewhere — Cloudflare DNS recommended)
DOMAIN=vectorless.store
API_HOSTNAME=api.vectorless.store

# ── Optional: pre-generated shared secrets. Leave blank to auto-generate.
#    If you set them here, the deploy scripts will reuse them; otherwise
#    they get generated and saved into this .env on first run.
UPSTREAM_AUTH_TOKEN=
OAUTH_JWT_SECRET=
DASHBOARD_SERVICE_TOKEN=
