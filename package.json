{
  "name": "vectorless-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@vectorless/api",
    "dev:web": "turbo dev --filter=@vectorless/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:sdk": "turbo test --filter=vectorless",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate --filter=@vectorless/api",
    "db:migrate": "turbo db:migrate --filter=@vectorless/api",
    "db:push": "turbo db:push --filter=@vectorless/api"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@10.15.0"
}
