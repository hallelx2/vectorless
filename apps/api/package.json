{
  "name": "@vectorless/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@google/genai": "^1.17.0",
    "@neondatabase/serverless": "^1.0.0",
    "@upstash/qstash": "^2.8.0",
    "@vectorless/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.3.0",
    "mammoth": "^1.9.0",
    "nanoid": "^5.1.0",
    "openai": "^4.90.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.4",
    "drizzle-kit": "^0.31.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
