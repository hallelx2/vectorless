# ============================================
# VECTORLESS API SERVER (.env.example)
# ============================================

# ── Database (Neon) ──────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Cloudflare R2 (Document File Storage) ────
# Stores original uploaded files for re-processing
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vectorless-docs
R2_PUBLIC_URL=

# ── QStash (Upstash — Background Job Queue) ──
QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── API Server ───────────────────────────────
API_BASE_URL=http://localhost:3001
PORT=3001

# ── LLM Provider ────────────────────────────
# Option A: Gemini via Vertex AI (recommended)
LLM_PROVIDER=gemini
GOOGLE_APPLICATION_CREDENTIALS=./vertex-credentials.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Option B: Anthropic (Claude)
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── OpenAI (Optional — hybrid retrieval only) ─
OPENAI_API_KEY=

# ── Auth ─────────────────────────────────────
BETTER_AUTH_SECRET=
